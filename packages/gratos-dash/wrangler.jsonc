{
  "name": "gratos-dash",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-03-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
  },
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true,
    },
  },
  "env": {
    "prod": {
      "vars": {
        "PUBLIC_GRATOS_SERVER": "https://authgravity.authgravity.org",
        "PUBLIC_PROVISIONER_SERVER": "https://provision.api.authgravity.org",
      },
      "routes": [
        {
          "pattern": "authgravity.org",
          "custom_domain": true,
        },
      ],
    },
  },
}
