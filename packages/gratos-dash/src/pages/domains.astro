---
import Layout from "../layouts/Layout.astro";
import { DomainList } from "../components/DomainList";

// Allow reading from Cloudflare runtime for dynamic variables
const env = (Astro.locals as any).runtime?.env || import.meta.env;
---

<Layout title="Domains">
  <DomainList
    client:only="preact"
    apiBaseUrl={env.PUBLIC_GRATOS_SERVER}
    provisionerBaseUrl={env.PUBLIC_PROVISIONER_SERVER}
  />
</Layout>
