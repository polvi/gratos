---
interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: system-ui, sans-serif;
        background: #fafafa;
        color: #18181b;
      }
      .container {
        max-width: 640px;
        margin: 0 auto;
        padding: 0 2rem;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      nav {
        padding: 2rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      nav .logo {
        font-weight: 800;
        font-size: 1.1rem;
        text-decoration: none;
        color: #18181b;
      }
      nav .links {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
      }
      nav .links a {
        text-decoration: none;
        color: #52525b;
        font-size: 0.9rem;
        font-weight: 500;
      }
      nav .links a.nav-button {
        background: #18181b;
        color: #fff;
        padding: 0.4rem 0.8rem;
        border-radius: 0.375rem;
        font-weight: 600;
      }
      nav .links a.nav-button:hover {
        background: #27272a;
      }
      nav .links a:hover:not(.nav-button) {
        color: #18181b;
      }
      nav .links a.active:not(.nav-button) {
        color: #18181b;
        font-weight: 600;
      }
      footer {
        margin-top: auto;
        padding: 2rem 0;
        border-top: 1px solid #e4e4e7;
        text-align: left;
        color: #a1a1aa;
        font-size: 0.75rem;
      }
      footer a {
        color: #a1a1aa;
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      footer a:hover {
        color: #52525b;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <nav>
        <a href="/" class="logo">Let's Ident</a>
        <div class="links">
          <a
            href="/about"
            class:list={[
              { active: pathname === "/about" || pathname === "/about/" },
            ]}>About</a
          >
          <a
            href="/signup"
            class:list={[
              { active: pathname === "/signup" || pathname === "/signup/" },
            ]}>Get Started</a
          >
          <a
            href="/login"
            class="nav-button"
            class:list={[
              { active: pathname === "/login" || pathname === "/login/" },
            ]}>Log In</a
          >
        </div>
      </nav>
      <slot />
      <footer>
        Copyright 2026 Alex Polvi. Licensed under the <a href="https://github.com/polvi/gratos" target="_blank" rel="noopener noreferrer">AGPLv3</a>.
      </footer>
    </div>
  </body>
</html>
