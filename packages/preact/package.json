{
    "name": "@gratos/preact",
    "version": "0.1.11",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "bun build ./src/index.tsx --outdir ./dist --external preact --external @simplewebauthn/browser && tsc",
        "release": "bun run build && node -e \"const p=require('./package.json');const v=p.version.split('.');v[2]=+v[2]+1;p.version=v.join('.');require('fs').writeFileSync('./package.json',JSON.stringify(p,null,4)+'\\n')\" && bun publish"
    },
    "dependencies": {
        "preact": "^10.28.2",
        "@simplewebauthn/browser": "^13.2.2"
    },
    "devDependencies": {
        "typescript": "^5.9.3"
    }
}
